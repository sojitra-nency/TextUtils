# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  TextUtils — frontend/.gitignore (React / CRA)                              │
# └─────────────────────────────────────────────────────────────────────────────┘

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Production build output ───────────────────────────────────────────────────
build/

# ── Environment files (never commit secrets) ──────────────────────────────────
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── CRA / Misc logs ───────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
