# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  TextUtils — Root .gitignore                                                │
# │  Covers monorepo-level files. Each sub-project has its own .gitignore too.  │
# └─────────────────────────────────────────────────────────────────────────────┘

# ── Root-level Node (concurrently + root tooling) ─────────────────────────────
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Claude Code ──────────────────────────────────────────────────────────────
.claude/

# ── IDEs & editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.pid
*.seed
*.pid.lock
