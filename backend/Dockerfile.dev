# Development — minimal single-stage image.
# Source code is mounted as a volume; uvicorn --reload watches for changes.

FROM python:3.12-slim

WORKDIR /app

# Create virtual environment
RUN python -m venv .venv

# Install dependencies into the venv
COPY requirements.txt .
RUN .venv/bin/pip install --upgrade pip --quiet && \
    .venv/bin/pip install --no-cache-dir -r requirements.txt

# Add venv to PATH so all commands use it
ENV PATH="/app/.venv/bin:$PATH"

# Source mounted at runtime via docker-compose volume.
# The anonymous volume in docker-compose.dev.yml keeps this .venv intact.
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
