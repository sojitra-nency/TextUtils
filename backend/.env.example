# Backend environment variables
# Copy this file to .env (git-ignored) and adjust values as needed.

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Groq API key for AI-powered hashtag generation (free at console.groq.com)
GROQ_API_KEY=

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Auth / JWT — CHANGE SECRET_KEY in production!
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (SQLite default, swap to PostgreSQL in production)
DATABASE_URL=sqlite+aiosqlite:///./fixmytext.db

# Google OAuth (get credentials at console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
